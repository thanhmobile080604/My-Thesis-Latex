@startuml activity_phan_tich_hieu_nang
' Render: tạo ảnh figures/activity_phan_tich_hieu_nang.png cho mục 2.3.4
skinparam defaultFontName "Times New Roman"
title Biểu đồ hoạt động: Phân tích hiệu năng Optical Flow

|Người dùng|
start
:Bấm Bắt đầu phân tích;
|Hệ thống|
:Khởi tạo 2 thuật toán, khóa độ nhạy ở mức tối đa;
while (Còn frame camera?) is (có)
  :Nhân đôi frame cho KLT và Farneback;
  fork
    :Chạy KLT, lấy metrics;
  fork again
    :Chạy Farneback, lấy metrics;
  end fork
  :Ghép kết quả trái-phải;
  :Ghi sample mỗi ~250 ms (FPS, process time, vectors...);
endwhile (không)
|Người dùng|
:Bấm Dừng phân tích;
|Hệ thống|
if (Có sample hợp lệ?) then (có)
  :Lưu AnalyticsSession (JSON);
else (không)
  :Không tạo phiên rỗng;
endif
:Mở lại phiên để xem biểu đồ;
stop
@enduml
