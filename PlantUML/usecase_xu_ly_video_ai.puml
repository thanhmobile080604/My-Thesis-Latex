@startuml usecase_xu_ly_video_ai
skinparam defaultFontName "Times New Roman"
skinparam linetype polyline
left to right direction
title Use case phân rã: Xử lý video Optical Flow bằng mô hình mạng lưới học sâu

actor "Người dùng" as User
actor "My Server" as MyS
actor "Outer Server" as OutS

rectangle "Xử lý video Optical Flow bằng mô hình mạng lưới học sâu" {
  usecase "Chọn video đầu vào" as U1
  usecase "Chọn backend và chế độ xử lý" as U2
  usecase "Upload video trực tiếp" as U3
  usecase "Upload video theo chunk" as U4
  usecase "Tạo job xử lý" as U5
  usecase "Theo dõi tiến độ job" as U6
  usecase "Hủy job" as U7
  usecase "Tải video kết quả" as U8
  usecase "Mở video đã xử lý" as U9
  usecase "Cleanup tài nguyên server" as U10
}

User --> U1
User --> U2
User --> U3
User --> U4
User --> U6
User --> U7
User --> U8
User --> U9
U3 ..> U5 : include
U4 ..> U5 : include
MyS --> U5
OutS --> U5
MyS --> U10
@enduml
