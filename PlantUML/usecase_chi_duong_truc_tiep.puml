@startuml usecase_chi_duong_truc_tiep
skinparam defaultFontName "Times New Roman"
skinparam linetype polyline
left to right direction
title Use case phân rã: Chỉ đường trực tiếp

actor "Người dùng" as User
actor "Dịch vụ định tuyến OSRM" as OSRM

rectangle "Chỉ đường trực tiếp" {
  usecase "Chọn điểm đến" as U1
  usecase "Bắt đầu dẫn đường" as U2
  usecase "Đánh giá chất lượng GNSS" as U3
  usecase "Bật camera assist" as U4
  usecase "Ước lượng chuyển động\nbằng Optical Flow/IMU" as U5
  usecase "Map matching theo route" as U6
  usecase "Cập nhật lại tuyến khi lệch đường" as U7
  usecase "Hiển thị path GNSS và path assist" as U8
}

User --> U1
User --> U2
User --> U3
User --> U4
User --> U5
User --> U6
User --> U7
User --> U8
OSRM --> U2
OSRM --> U7
@enduml
