@startuml
title Luong xu ly video RAFT bat dong bo

actor "Nguoi dung" as User
participant "Android App" as App
participant "VideoProcessingForegroundService" as Service
participant "OpticalFlowServerApi" as Client
participant "FastAPI Server" as API
participant "VideoJob Store" as Store
participant "OpticalFlowProcessor" as Processor
participant "ONNX Runtime" as ONNX

User -> App : Chon video va che do xu ly
App -> Service : start processing intent
Service -> Client : createProcessVideoJob(file, fields)
Client -> API : POST /process-video/jobs
API -> Store : create VideoJob(status=queued)
API --> Client : job_id

loop polling
  Service -> Client : getProcessVideoJob(job_id)
  Client -> API : GET /process-video/jobs/{job_id}
  API --> Client : status, progress
  Service -> App : update overlay message
end

API -> Processor : process_video(input, output)
Processor -> ONNX : session.run(prev, curr)
ONNX --> Processor : flow outputs
Processor -> Processor : draw vectors/heatmap
Processor -> Store : update progress/completed

Service -> Client : download result
Client -> API : GET /process-video/jobs/{job_id}/result
API --> Client : output mp4
Service -> App : processedVideoPathToOpen
App -> User : Mo video ket qua

@enduml
