@startuml activity_quan_sat_ve_tinh
' Render: tạo ảnh figures/activity_quan_sat_ve_tinh.png cho mục 2.3.1
skinparam defaultFontName "Times New Roman"
title Biểu đồ hoạt động: Quan sát vệ tinh

|Người dùng|
start
:Mở màn hình Quan sát vệ tinh;
|Hệ thống|
:Khởi tạo bản đồ osmdroid;
:Đăng ký LocationManager và GnssStatus.Callback;
:Hiển thị marker vị trí người dùng;
while (Còn cập nhật GNSS?) is (có)
  :Nhận GnssStatus;
  :Phân giải vị trí vệ tinh theo chuỗi ưu tiên\n(PVT -> IGS -> CelesTrak -> Xấp xỉ);
  :Cập nhật danh sách vệ tinh;
endwhile (không)
|Người dùng|
:Chọn thao tác;
if (Tìm địa điểm?) then (đúng)
  |Hệ thống|
  :Gọi Nominatim, vẽ tuyến đường OSRM;
elseif (Xem mô hình 3D?) then (đúng)
  |Hệ thống|
  :Dựng Trái Đất 3D, đặt vệ tinh theo nguồn dữ liệu;
elseif (Xem AR?) then (đúng)
  |Hệ thống|
  :Phủ thông tin vệ tinh lên luồng camera;
else (Xem chi tiết)
  |Hệ thống|
  :Hiển thị chi tiết vệ tinh và nguồn phân giải vị trí;
endif
stop
@enduml
