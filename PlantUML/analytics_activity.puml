@startuml
title Activity phiên analytics KLT/Farneback

start
:Người dùng bấm Start Analysis;
:Khóa độ nhạy KLT và Farneback ở mức 100;
:Vô hiệu hóa ghi video và đổi mode;
while (Còn frame camera?) is (có)
  :Clone frame thành 2 bản;
  fork
    :Chạy KLT;
    :Lấy KLT metrics;
  fork again
    :Chạy Farneback;
    :Lấy Farneback metrics;
  end fork
  :Ghép frame trái-phải;
  :Vẽ overlay thông số;
  :Tạo AnalyticsSample;
  :Lưu sample vào session tạm;
endwhile (không)
:Người dùng bấm Stop Analysis;
if (Có sample hợp lệ?) then (có)
  :Tạo AnalyticsSession;
  :Lưu JSON bằng AnalyticsStorageUtil;
else (không)
  :Thông báo không có sample;
endif
:Khôi phục điều khiển giao diện;
stop

@enduml
